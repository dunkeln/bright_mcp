{
  "name": "bright-mcp-evals",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "agent": "MCPJAM_TELEMETRY_DISABLED=1 bun run src/agent.ts",
    "judge": "bun run src/judge.ts",
    "check": "MCPJAM_TELEMETRY_DISABLED=1 bun run src/check.ts",
    "usecases": "MCPJAM_TELEMETRY_DISABLED=1 bun run src/usecases.ts",
    "eval": "bun run check && bun run usecases && bun run agent && bun run judge",
    "report:check": "bun run src/report.ts --check && bun ../scripts/render-benchmark-chart.ts --check",
    "report:write": "bun run src/report.ts --write && bun ../scripts/render-benchmark-chart.ts --write",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mcpjam/sdk": "2.0.0",
    "@modelcontextprotocol/sdk": "1.29.0"
  },
  "devDependencies": {
    "@mcpjam/cli": "3.15.2",
    "@types/bun": "1.3.14",
    "typescript": "7.0.2"
  }
}
