---
import { Github } from "lucide-astro";

const repoUrl = "https://github.com/dunkeln/bright_mcp";
---

<header class="site-header-section">
  <div class="site-header">
    <a class="brand" href="/" aria-label="Bright MCP home">
      <img src="/assets/icon.png" alt="" width="32" height="32" />
      <span>Bright MCP</span>
    </a>
    <nav aria-label="Primary navigation">
      <a href="/#overview">Overview</a>
      <a href="/#install">Install</a>
      <a href="/benchmark">Bench</a>
      <a href="/#start">Docs</a>
    </nav>
    <a class="github" href={repoUrl} target="_blank" rel="noreferrer" aria-label="View Bright MCP on GitHub">
      <Github aria-hidden="true" />
    </a>
  </div>
</header>

<style>
  .site-header-section { background: #151515; border-bottom: 1px solid #ffffff17; color: #f2f2f2; position: relative; z-index: 3; }
  .site-header {
    align-items: center;
    border-inline: 1px solid #ffffff17;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    height: 64px;
    margin-inline: auto;
    max-width: 1280px;
    padding: 0 16px;
  }
  a { color: inherit; text-decoration: none; }
  .brand { align-items: center; display: inline-flex; font-size: 22px; font-weight: 700; gap: 16px; height: 100%; line-height: 1; }
  .brand img { border-radius: 22%; display: block; height: 32px; object-fit: cover; width: 32px; }
  nav { display: flex; gap: 38px; }
  nav a { color: #bdbdbd; font: 14px Inter, Arial, sans-serif; }
  nav a:hover { color: white; }
  .github {
    align-items: center;
    background: #f4f4f4;
    border: 1px solid #ffffff22;
    border-radius: 7px;
    color: #171717;
    display: inline-flex;
    height: 42px;
    justify-content: center;
    justify-self: end;
    width: 42px;
  }
  .github:hover { background: white; }
  .github :global(svg) { height: 20px; stroke-width: 1.8; width: 20px; }
  @media (max-width: 760px) {
    .site-header { grid-template-columns: 1fr auto; }
    nav { display: none; }
  }
</style>
