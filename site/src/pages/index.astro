---
import HeroDither from "../components/HeroDither";
import { Check, ChevronDown, Copy, Download } from "lucide-astro";

const startUrl = "#install";
const cursorInstallUrl =
  "cursor://anysphere.cursor-deeplink/mcp/install?name=bright&config=eyJ1cmwiOiJodHRwczovL2JyaWdodC1tY3Aub25yZW5kZXIuY29tL21jcCJ9";
const clients = [
  {
    name: "Codex",
    icon: "/assets/openai.svg",
    command: "codex mcp add bright --url https://bright-mcp.onrender.com/mcp",
    action: "copy",
  },
  {
    name: "Claude Code",
    icon: "/assets/anthropic.svg",
    command: "claude mcp add --transport http bright https://bright-mcp.onrender.com/mcp",
    action: "copy",
  },
  {
    name: "Cursor",
    icon: "/assets/cursor.svg",
    command: "Install Bright MCP in Cursor",
    action: "open",
    href: cursorInstallUrl,
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta
      name="description"
      content="Bright MCP gives agents a small, task-oriented interface to Bright Data."
    />
    <title>Bright MCP</title>
  </head>
  <body>
    <header class="site-header-section">
      <div class="site-header rail gutter-left gutter-right">
        <a class="brand header-brand" href="/" aria-label="Bright MCP home">
          <img
            class="brand-icon"
            src="/assets/icon.png"
            alt=""
            width="32"
            height="32"
          />
          <span>Bright MCP</span>
        </a>
        <nav aria-label="Primary navigation">
          <a href="#overview">Overview</a>
          <a href="#install">Install</a>
          <a href="#bench">Bench</a>
          <a href="#start">Docs</a>
        </nav>
        <a class="button button-light header-button" href={startUrl}>Read docs</a>
      </div>
    </header>

    <main>
      <section class="section-shell" id="overview">
        <div class="hero rail gutter-left gutter-right">
          <div class="hero-gutter-leak"><HeroDither client:load variant="gutter" /></div>
          <div class="hero-media"><HeroDither client:load /></div>
          <div class="hero-content">
            <span class="announcement"><i></i>Web data where agent work happens<b>›</b></span>
            <h1>From a cold start to<br />useful web data.</h1>
            <p></p>
            <a class="button button-light" href={startUrl}>Read docs</a>
          </div>
        </div>
      </section>

      <section class="section-shell" id="install">
        <div class="command-intro dot-grid rail gutter-left gutter-right">
          <p class="label">Install</p>
          <h2>Connect Bright MCP to your agent</h2>
          <div class="install-command">
            <details class="client-picker">
              <summary>
                <img class="client-icon" src={clients[0].icon} alt="" />
                <span>{clients[0].name}</span>
                <ChevronDown class="chevron-icon" aria-hidden="true" />
              </summary>
              <div class="client-menu">
                {clients.map((client) => (
                  <button
                    class="client-option"
                    type="button"
                    data-name={client.name}
                    data-icon={client.icon}
                    data-command={client.command}
                    data-action={client.action}
                    data-href={client.href}
                  >
                    <img class="client-icon" src={client.icon} alt="" />
                    <span>{client.name}</span>
                  </button>
                ))}
              </div>
            </details>
            <code class="install-value">{clients[0].command}</code>
            <button class="copy" type="button" aria-label="Copy install command">
              <Copy class="copy-icon" aria-hidden="true" />
              <Check class="check-icon" aria-hidden="true" />
              <Download class="install-icon" aria-hidden="true" />
            </button>
          </div>
          <p class="meta">
            Open source <span>·</span> MIT licensed <span>|</span>
            <img class="bun-logo" src="/assets/bun.svg" alt="Built with Bun" title="Built with Bun" />
          </p>
        </div>
      </section>

      <section class="section-shell" id="bench">
        <div class="bench rail gutter-left gutter-right">
          <div class="bench-heading">
            <p class="label">Lorem ipsum</p>
            <h2>Lorem ipsum dolor sit amet</h2>
            <p>Lorem ipsum dolor sit amet, consectetur adipiscing elit.</p>
          </div>
          <div class="bench-results">
            <article><small>01</small><strong>00.0</strong><p>Lorem ipsum</p></article>
            <article><small>02</small><strong>00ms</strong><p>Dolor sit</p></article>
            <article><small>03</small><strong>0 / 0</strong><p>Amet elit</p></article>
            <article><small>04</small><strong>00%</strong><p>Consectetur</p></article>
            <article><small>05</small><strong>0.00</strong><p>Adipiscing</p></article>
          </div>
        </div>
      </section>

      <section class="section-shell" id="start">
        <div class="cta rail gutter-left gutter-right">
          <div>
            <p class="label">Bright MCP</p>
            <h2>Five tools. One clear path to web data.</h2>
            <p>Discover, inspect, and run Bright Data capabilities without exposing the entire upstream API.</p>
          </div>
          <a class="button button-light" href="#overview">Get started</a>
        </div>
      </section>
    </main>

    <footer class="footer-shell">
      <div class="site-footer rail gutter-left gutter-right">
        <a class="brand" href="/">Bright MCP</a>
        <div>
          <strong>Product</strong>
          <a href="#overview">Overview</a>
          <a href="#install">Install</a>
        </div>
        <div>
          <strong>Resources</strong>
          <a href="#bench">Benchmarks</a>
          <a href="#start">Get started</a>
        </div>
        <span>© 2026</span>
      </div>
    </footer>
  </body>
</html>

<script>
  const picker = document.querySelector<HTMLDetailsElement>(".client-picker");
  const selectedIcon = picker?.querySelector<HTMLImageElement>("summary img");
  const selectedName = picker?.querySelector<HTMLElement>("summary span");
  const command = document.querySelector<HTMLElement>(".install-value");
  const copy = document.querySelector<HTMLButtonElement>(".install-command .copy");

  picker?.querySelectorAll<HTMLButtonElement>(".client-option").forEach((option) => {
    option.addEventListener("click", () => {
      if (selectedIcon) selectedIcon.src = option.dataset.icon ?? "";
      if (selectedName) selectedName.textContent = option.dataset.name ?? "";
      if (command) command.textContent = option.dataset.command ?? "";
      if (copy) {
        copy.dataset.action = option.dataset.action ?? "copy";
        copy.dataset.href = option.dataset.href ?? "";
        copy.classList.toggle("install-action", option.dataset.action === "open");
      }
      picker.open = false;
      copy?.classList.remove("copied");
      copy?.setAttribute(
        "aria-label",
        option.dataset.action === "open" ? "Install Bright MCP in Cursor" : "Copy install command",
      );
    });
  });

  copy?.addEventListener("click", async () => {
    if (copy.dataset.action === "open") {
      window.location.href = copy.dataset.href ?? "";
      return;
    }
    await navigator.clipboard.writeText(command?.textContent ?? "");
    copy.classList.add("copied");
    copy.setAttribute("aria-label", "Copied");
  });
</script>

<style>
  :global(*) { box-sizing: border-box; }
  :global(html) { scroll-behavior: smooth; }
  :global(body) {
    --bg: #141414;
    --line: #ffffff17;
    --muted: #aaa;
    --accent: #8da8c7;
    background: var(--bg);
    color: #f2f2f2;
    font-family: Inter, Arial, sans-serif;
    margin: 0;
    overflow-x: hidden;
  }
  :global(a) { color: inherit; text-decoration: none; }
  h1, h2, p { margin-top: 0; }

  .section-shell,
  .site-header-section { border-bottom: 1px solid var(--line); }

  .rail {
    margin-inline: auto;
    max-width: 1280px;
    width: 100%;
  }

  .site-header-section {
    background: #151515;
    position: relative;
    z-index: 3;
  }

  .site-header {
    align-items: center;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    height: 64px;
    padding: 0 16px;
  }

  .brand {
    font-size: 28px;
    font-weight: 700;
    line-height: 1;
  }

  .header-brand {
    align-items: center;
    display: inline-flex;
    font-size: 22px;
    gap: 16px;
    height: 100%;
  }

  .brand-icon {
    border-radius: 22%;
    display: block;
    flex: 0 0 32px;
    height: 32px;
    object-fit: cover;
    width: 32px;
  }

  nav { display: flex; gap: 38px; }
  nav a { color: #bdbdbd; font-size: 14px; }
  nav a:hover,
  .site-footer a:hover { color: white; }
  .header-button { justify-self: end; }

  .button {
    border: 1px solid #ffffff22;
    border-radius: 7px;
    display: inline-flex;
    font-size: 14px;
    justify-content: center;
    padding: 11px 16px;
  }

  .button-light { background: #f4f4f4; color: #171717; }
  .button-light:hover { background: white; }

  .hero {
    align-items: center;
    display: flex;
    justify-content: center;
    min-height: 560px;
    overflow: visible;
    position: relative;
    text-align: center;
  }

  .hero-gutter-leak { display: none; }

  .hero-media {
    background-color: #20212a;
    inset: 0;
    overflow: hidden;
    position: absolute;
    z-index: 1;
  }

  .hero-gutter-leak :global(canvas),
  .hero-media :global(canvas) {
    display: block;
  }

  .hero-media::after {
    background: linear-gradient(#14151a22, #14151a77);
    content: '';
    inset: 0;
    position: absolute;
  }

  .hero-content {
    max-width: 700px;
    padding: 70px 24px;
    position: relative;
    z-index: 2;
  }

  .announcement {
    align-items: center;
    background: #ffffff12;
    border: 1px solid #ffffff12;
    border-radius: 7px;
    color: #e2e2e2;
    display: inline-flex;
    font-size: 13px;
    gap: 10px;
    padding: 8px 12px;
  }

  .announcement i {
    background: #9ff;
    border-radius: 50%;
    box-shadow: 0 0 8px #8ff;
    height: 7px;
    width: 7px;
  }

  .announcement b {
    color: #aaa;
    font-size: 18px;
    font-weight: 400;
  }

  .hero h1 {
    font-size: clamp(34px, 4vw, 48px);
    font-weight: 600;
    letter-spacing: 0;
    line-height: 1;
    margin: 26px 0 16px;
  }

  .hero-content > p {
    font-size: 16px;
    line-height: 1.45;
    margin: 0 auto 26px;
    max-width: 590px;
  }

  .label {
    color: var(--accent);
    font: 500 11px/1.2 "SFMono-Regular", Consolas, monospace;
    margin: 0;
    text-transform: uppercase;
  }

  .dot-grid {
    background-color: var(--bg);
    background-image: radial-gradient(#ffffff0c 1px, transparent 1px);
    background-size: 16px 16px;
  }

  .command-intro {
    align-items: center;
    display: flex;
    flex-direction: column;
    min-height: 315px;
    padding: 62px 20px 38px;
    text-align: center;
  }

  .command-intro h2,
  .bench-heading h2 {
    font-size: 24px;
    font-weight: 600;
    line-height: 1.15;
    margin: 12px 0 0;
  }

  .install-command {
    align-items: stretch;
    background: #202020;
    border: 1px solid var(--line);
    border-radius: 7px;
    display: grid;
    grid-template-columns: 150px minmax(0, 1fr) 64px;
    margin-top: 32px;
    max-width: 820px;
    width: 100%;
  }

  .client-picker { border-right: 1px solid var(--line); position: relative; }
  .client-picker summary,
  .client-option,
  .install-command .copy {
    align-items: center;
    background: transparent;
    border: 0;
    color: inherit;
    cursor: pointer;
    display: flex;
    font: inherit;
    font-size: 13px;
    min-height: 50px;
  }

  .client-picker summary {
    gap: 10px;
    list-style: none;
    padding: 0 16px;
  }

  .client-picker summary::-webkit-details-marker { display: none; }
  .client-picker summary :global(.chevron-icon) {
    flex: 0 0 auto;
    height: 16px;
    margin-left: auto;
    stroke-width: 1.8;
    width: 16px;
  }
  .client-icon { display: block; height: 20px; object-fit: contain; width: 20px; }
  .client-icon[src$="openai.svg"] { filter: invert(1); }

  .client-menu {
    background: #202020;
    border: 1px solid #ffffff24;
    border-radius: 7px;
    box-shadow: 0 16px 40px #0008;
    left: -1px;
    overflow: hidden;
    padding: 5px;
    position: absolute;
    top: calc(100% + 8px);
    width: 182px;
    z-index: 4;
  }

  .client-option { gap: 10px; min-height: 42px; padding: 0 11px; width: 100%; }
  .client-option:hover,
  .client-option:focus-visible { background: #ffffff0d; border-radius: 5px; outline: none; }

  .install-command .copy {
    border-left: 1px solid var(--line);
    justify-content: center;
  }

  .copy :global(svg) { height: 21px; stroke-width: 1.6; width: 21px; }
  .copy :global(.check-icon),
  .copy :global(.install-icon) { display: none; }
  .copy.copied :global(.copy-icon),
  .copy.install-action :global(.copy-icon) { display: none; }
  .copy.copied :global(.check-icon) { color: #9fc4a7; display: block; }
  .copy.install-action :global(.install-icon) { display: block; }

  .install-command code {
    align-items: center;
    color: #c8c8c8;
    display: flex;
    font: 13px "SFMono-Regular", Consolas, monospace;
    overflow-x: auto;
    padding: 0 18px;
    text-align: left;
    white-space: nowrap;
  }

  .meta { align-items: center; color: #9d9d9d; display: flex; font-size: 13px; margin: 24px 0 0; }
  .meta span { margin: 0 8px; }
  .bun-logo { height: 21px; margin-left: 1px; width: 24px; }

  .bench-heading {
    align-items: center;
    background-color: var(--bg);
    background-image: radial-gradient(#ffffff0c 1px, transparent 1px);
    background-size: 16px 16px;
    display: flex;
    flex-direction: column;
    min-height: 210px;
    padding: 52px 20px 36px;
    text-align: center;
  }

  .bench-heading > p:last-child {
    color: var(--muted);
    font-size: 14px;
    line-height: 1.5;
    margin: 12px 0 0;
  }

  .bench-results { display: grid; grid-template-columns: repeat(5, 1fr); }
  .bench-results article {
    min-height: 150px;
    padding: 26px 24px;
  }
  .bench-results article + article { border-left: 1px solid var(--line); }
  .bench-results small {
    color: var(--accent);
    display: block;
    font: 10px "SFMono-Regular", Consolas, monospace;
  }
  .bench-results strong { display: block; font-size: 24px; margin-top: 23px; }
  .bench-results p { color: var(--muted); font-size: 12px; margin: 7px 0 0; }

  .cta {
    align-items: center;
    display: flex;
    justify-content: space-between;
    min-height: 230px;
    padding: 48px 5%;
  }

  .cta h2 {
    font-size: 32px;
    font-weight: 600;
    line-height: 1.15;
    margin: 12px 0 0;
  }

  .cta > div > p:last-child {
    color: var(--muted);
    font-size: 14px;
    line-height: 1.5;
    margin: 14px 0 0;
    max-width: 560px;
  }

  .site-footer {
    display: grid;
    gap: 30px;
    grid-template-columns: 2fr 1fr 1fr auto;
    min-height: 220px;
    padding: 44px 32px;
  }

  .site-footer div {
    display: flex;
    flex-direction: column;
    font-size: 13px;
    gap: 8px;
  }

  .site-footer strong { margin-bottom: 6px; }
  .site-footer span {
    color: #777;
    font: 11px "SFMono-Regular", Consolas, monospace;
  }

  @media (min-width: 1280px) {
    .gutter-left {
      border-left-color: var(--gutter-left-color, var(--line));
      border-left-style: solid;
      border-left-width: var(--gutter-left-width, 1px);
    }

    .gutter-right {
      border-right-color: var(--gutter-right-color, var(--line));
      border-right-style: solid;
      border-right-width: var(--gutter-right-width, 1px);
    }
  }

  @media (min-width: 1281px) {
    .hero-gutter-leak {
      -webkit-mask-image: linear-gradient(
        90deg,
        transparent 0,
        #000 calc(50% - 640px),
        transparent calc(50% - 628px),
        transparent calc(50% + 628px),
        #000 calc(50% + 640px),
        transparent 100%
      );
      clip-path: inset(0);
      display: block;
      filter: blur(0.6px);
      inset-block: 0;
      left: 50%;
      mask-image: linear-gradient(
        90deg,
        transparent 0,
        #000 calc(50% - 640px),
        transparent calc(50% - 628px),
        transparent calc(50% + 628px),
        #000 calc(50% + 640px),
        transparent 100%
      );
      mix-blend-mode: screen;
      opacity: 0.3;
      overflow: hidden;
      pointer-events: none;
      position: absolute;
      transform: translateX(-50%);
      width: 100vw;
      z-index: 0;
    }
  }

  @media (max-width: 760px) {
    .site-header { grid-template-columns: 1fr auto; }
    .site-header nav { display: none; }
    .hero { min-height: 520px; }
    .hero h1 { font-size: 36px; }
    .bench-results { grid-template-columns: repeat(2, 1fr); }
    .bench-results article { border-bottom: 1px solid var(--line); }
    .bench-results article:nth-child(odd) { border-left: 0; }
    .bench-results article:last-child { grid-column: 1 / -1; }
    .cta {
      align-items: flex-start;
      flex-direction: column;
      gap: 28px;
      padding: 42px 24px;
    }
    .site-footer { grid-template-columns: 1fr 1fr; }
    .site-footer > .brand { grid-column: 1 / -1; }
  }

  @media (max-width: 480px) {
    .install-command { grid-template-columns: 54px minmax(0, 1fr) 46px; }
    .client-picker summary { justify-content: center; padding: 0; }
    .client-picker summary span,
    .client-picker summary :global(.chevron-icon) { display: none; }
    .install-command code { font-size: 11px; padding: 0 10px; }
  }
</style>
