{
  "name": "bright-mcp-evals",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "agent": "bun run src/agent.ts",
    "check": "bun run src/check.ts",
    "usecases": "bun run src/usecases.ts",
    "eval": "bun run check && bun run usecases && bun run agent",
    "report:check": "bun run src/report.ts --check && bun ../scripts/render-benchmark-chart.ts --check",
    "report:write": "bun ../scripts/render-benchmark-chart.ts --write && bun run src/report.ts --write",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mcpjam/sdk": "2.0.0",
    "@modelcontextprotocol/sdk": "1.29.0"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "typescript": "7.0.2"
  }
}
