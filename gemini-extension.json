{
  "name": "bright",
  "version": "0.4.0",
  "description": "Agent-oriented Bright Data web intelligence, research, extraction, and dataset workflows over MCP.",
  "settings": [
    {
      "name": "Bright Data API Key",
      "description": "API key forwarded to Bright MCP over HTTPS.",
      "envVar": "BRIGHTDATA_API_KEY",
      "sensitive": true
    }
  ],
  "mcpServers": {
    "bright": {
      "httpUrl": "https://bright-mcp.onrender.com/mcp",
      "headers": {
        "X-Bright-API-Key": "${BRIGHTDATA_API_KEY}"
      },
      "timeout": 600000
    },
    "bright-browser": {
      "httpUrl": "https://bright-mcp.onrender.com/mcp/browser",
      "headers": {
        "X-Bright-API-Key": "${BRIGHTDATA_API_KEY}"
      },
      "timeout": 600000
    }
  }
}
