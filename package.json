{
  "name": "bright_mcp",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "benchmark": "bun run evals && bun run report:write && bun run report:check",
    "build": "bun run scripts/build-app.ts",
    "check:adapters": "bun run checks/adapter-compatibility.ts",
    "check:auth": "bun run checks/auth-compatibility.ts",
    "check:browser": "bun run checks/browser-compatibility.ts",
    "check:compat": "bun run checks/compatibility.ts",
    "check:connection": "bun run checks/connection-compatibility.ts",
    "check:coverage": "bun run checks/coverage.ts",
    "connect:brightdata": "bun run scripts/brightdata-connection.ts connect",
    "dev": "bun --watch src/main.ts",
    "dev:app": "bun run scripts/dev-app.ts",
    "disconnect:brightdata": "bun run scripts/brightdata-connection.ts disconnect",
    "evals": "bun --cwd evals run eval",
    "report:check": "bun --cwd evals run report:check",
    "report:write": "bun --cwd evals run report:write",
    "start": "bun run src/main.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@tailwindcss/cli": "4.3.3",
    "@types/bun": "1.3.14",
    "@types/d3-scale": "4.0.9",
    "@types/d3-shape": "3.1.8",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "typescript": "7.0.2"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "1.7.4",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@openai/apps-sdk-ui": "0.2.2",
    "clsx": "2.1.1",
    "d3-scale": "4.0.2",
    "d3-shape": "3.2.0",
    "jose": "6.2.3",
    "lru-cache": "11.5.2",
    "motion": "12.42.2",
    "p-limit": "7.2.0",
    "playwright-core": "1.61.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwind-merge": "3.6.0",
    "tailwindcss": "4.3.3",
    "zod": "4.4.3"
  }
}
