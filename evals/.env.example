# Required by the published Bright Data MCP. Never commit the real value.
BRIGHTDATA_API_KEY=

# MCPJam routes this pinned model through OpenRouter.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
# A stronger model slug used for blind paired quality judgments.
OPENROUTER_JUDGE=
EVAL_RUNS=10
# Independent jobs run in Bright/BrightData pairs; keep this even.
EVAL_CONCURRENCY=4
